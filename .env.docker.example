# Docker environment for mavedb-link behind Nginx Proxy Manager.
# Copy to .env.docker for the NPM compose deployment:
#
#   cp .env.docker.example .env.docker
#
# The image and docker/docker-compose.npm.yml carry safe defaults. This file
# pins the shared NPM network and exposes the production knobs that are commonly
# tuned on the VPS without editing the compose file.

# ---- Nginx Proxy Manager (docker/docker-compose.npm.yml) ----
# External NPM network the container joins for reverse-proxy routing.
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Server / transport ----
MAVEDB_LINK_HOST=0.0.0.0
MAVEDB_LINK_PORT=8000
MAVEDB_LINK_TRANSPORT=unified
MAVEDB_LINK_MCP_PATH=/mcp

# ---- Local mirror + mapped-variant cache ----
# Persist the mirror and lazy mapped-variant cache in the Docker volume.
MAVEDB_LINK_MIRROR__DATA_DIR=/home/app/data
MAVEDB_LINK_CACHE__DB_PATH=/home/app/data/mavedb_cache.sqlite

# Disable the mirror for live-only serving.
# MAVEDB_LINK_MIRROR__ENABLED=false

# Build from the Zenodo dump if no prebuilt release artifact is available.
# MAVEDB_LINK_MIRROR__BUILD_LOCAL=true

# Override the upstream API only when using a mirror or test endpoint.
# MAVEDB_LINK_API__BASE_URL=https://api.mavedb.org/api/v1

# ---- Logging ----
LOG_LEVEL_API=INFO
MAVEDB_LINK_LOG_FORMAT=json

# ---- NPM resource limits (optional) ----
MAVEDB_API_MEMORY_LIMIT=1g
MAVEDB_API_CPU_LIMIT=1.0

# mavedb-link configuration (copy to .env). All vars use the MAVEDB_LINK_ prefix;
# nested config uses __ (e.g. MAVEDB_LINK_API__BASE_URL).

# --- Server ---
MAVEDB_LINK_HOST=127.0.0.1
MAVEDB_LINK_PORT=8000
MAVEDB_LINK_TRANSPORT=unified           # unified | http | stdio
MAVEDB_LINK_MCP_PATH=/mcp
# Exact JSON allowlists. Add the public reverse-proxy hostname in production.
MAVEDB_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
MAVEDB_LINK_ALLOWED_ORIGINS=[]
MAVEDB_LINK_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
MAVEDB_LINK_LOG_FORMAT=console          # console | json

# --- Upstream MaveDB API (public, read-only — no credentials required) ---
MAVEDB_LINK_API__BASE_URL=https://api.mavedb.org/api/v1
MAVEDB_LINK_API__REQUEST_TIMEOUT=30
MAVEDB_LINK_API__MAX_CONCURRENCY=5
MAVEDB_LINK_API__CACHE_TTL=600

# --- Build provenance (normally injected by the Docker build) ---
# MAVEDB_LINK_GIT_SHA=
# MAVEDB_LINK_BUILT_AT=

{
  "$comment": "This checked-in schema enforces structural constraints. Acceptance additionally requires semantic validation through ReleaseConfig or ApplicationReleaseManifest; cross-field equality is enforced by Pydantic validators.",
  "$defs": {
    "ArtifactIdentity": {
      "additionalProperties": false,
      "properties": {
        "compressed_size": {
          "minimum": 1,
          "title": "Compressed Size",
          "type": "integer"
        },
        "expanded_size": {
          "minimum": 1,
          "title": "Expanded Size",
          "type": "integer"
        },
        "expanded_tree_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Expanded Tree Sha256",
          "type": "string"
        },
        "filename": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,255}$",
          "title": "Filename",
          "type": "string"
        },
        "max_compressed_size": {
          "minimum": 1,
          "title": "Max Compressed Size",
          "type": "integer"
        },
        "max_expanded_size": {
          "minimum": 1,
          "title": "Max Expanded Size",
          "type": "integer"
        },
        "max_members": {
          "minimum": 1,
          "title": "Max Members",
          "type": "integer"
        },
        "member_count": {
          "minimum": 1,
          "title": "Member Count",
          "type": "integer"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "filename",
        "sha256",
        "compressed_size",
        "max_compressed_size",
        "expanded_tree_sha256",
        "expanded_size",
        "max_expanded_size",
        "member_count",
        "max_members"
      ],
      "title": "ArtifactIdentity",
      "type": "object"
    },
    "CompatibilityRange": {
      "additionalProperties": false,
      "properties": {
        "maximum": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Maximum",
          "type": "string"
        },
        "minimum": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Minimum",
          "type": "string"
        }
      },
      "required": [
        "minimum",
        "maximum"
      ],
      "title": "CompatibilityRange",
      "type": "object"
    },
    "DatasetIdentity": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "release": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Release",
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/UpstreamSource"
        }
      },
      "required": [
        "name",
        "release",
        "source"
      ],
      "title": "DatasetIdentity",
      "type": "object"
    },
    "LicenseEvidence": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "redistribution_allowed": {
          "title": "Redistribution Allowed",
          "type": "boolean"
        },
        "reviewed_at": {
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$",
          "title": "Reviewed At",
          "type": "string"
        },
        "reviewer": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reviewer",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "minLength": 1,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "name",
        "url",
        "redistribution_allowed",
        "reviewed_at",
        "reviewer"
      ],
      "title": "LicenseEvidence",
      "type": "object"
    },
    "SchemaIdentity": {
      "additionalProperties": false,
      "properties": {
        "actual": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Actual",
          "type": "string"
        },
        "maximum": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Maximum",
          "type": "string"
        },
        "minimum": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
          "title": "Minimum",
          "type": "string"
        }
      },
      "required": [
        "minimum",
        "maximum",
        "actual"
      ],
      "title": "SchemaIdentity",
      "type": "object"
    },
    "TransformationIdentity": {
      "additionalProperties": false,
      "properties": {
        "repository": {
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9_.-]{0,38})/[A-Za-z0-9_.-]{1,100}$",
          "title": "Repository",
          "type": "string"
        },
        "revision": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Revision",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "revision"
      ],
      "title": "TransformationIdentity",
      "type": "object"
    },
    "UpstreamSource": {
      "additionalProperties": false,
      "properties": {
        "etag": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Etag"
        },
        "identifier": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Identifier",
          "type": "string"
        },
        "last_modified": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Modified"
        },
        "retrieved_at": {
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$",
          "title": "Retrieved At",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "url": {
          "format": "uri",
          "minLength": 1,
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "identifier",
        "url",
        "retrieved_at",
        "sha256"
      ],
      "title": "UpstreamSource",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable and independently rollbackable reference-data release.",
  "properties": {
    "application_compatibility": {
      "$ref": "#/$defs/CompatibilityRange"
    },
    "artifact": {
      "$ref": "#/$defs/ArtifactIdentity"
    },
    "dataset": {
      "$ref": "#/$defs/DatasetIdentity"
    },
    "disclaimer": {
      "maxLength": 1000,
      "minLength": 20,
      "title": "Disclaimer",
      "type": "string"
    },
    "license": {
      "$ref": "#/$defs/LicenseEvidence"
    },
    "previous_known_good_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Previous Known Good Digest",
      "type": "string"
    },
    "record_counts": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "minProperties": 1,
      "title": "Record Counts",
      "type": "object"
    },
    "schema": {
      "$ref": "#/$defs/SchemaIdentity"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "transformation": {
      "$ref": "#/$defs/TransformationIdentity"
    }
  },
  "required": [
    "dataset",
    "transformation",
    "schema",
    "record_counts",
    "artifact",
    "license",
    "previous_known_good_digest",
    "application_compatibility",
    "disclaimer"
  ],
  "title": "DataReleaseManifest",
  "type": "object"
}
